<block>
	<children>
		<package>
			<string-list for="namespace">
				<child value="magma"/>
			<string-list/>
		<package/>
		<import>
			<string-list for="namespace">
				<child value="magma"/>
				<child value="app"/>
				<child value="Application"/>
			<string-list/>
		<import/>
		<import>
			<string-list for="namespace">
				<child value="magma"/>
				<child value="app"/>
				<child value="ApplicationException"/>
			<string-list/>
		<import/>
		<import>
			<string-list for="namespace">
				<child value="java"/>
				<child value="nio"/>
				<child value="file"/>
				<child value="Path"/>
			<string-list/>
		<import/>
		<class name="Main">
			<string-list for="modifiers">
				<child value="public"/>
			<string-list/>
			<children>
				<method>
					<definition name="main" for="definition">
						<string-list for="modifiers">
							<child value="public"/>
							<child value="static"/>
						<string-list/>
						<symbol for="type" value="void"/>
					<definition/>
					<params>
						<definition name="args">
							<array for="type">
								<symbol for="child" value="String"/>
							<array/>
						<definition/>
					<params/>
					<children>
						<any value="try {
            var source = resolveMain();
            var application = new Application(source);
            application.run();
        }"/>
						<any value="catch (ApplicationException e) {
            //noinspection CallToPrintStackTrace
            e.printStackTrace();
        }"/>
					<children/>
				<method/>
				<method>
					<definition name="resolveMain" for="definition">
						<string-list for="modifiers">
							<child value="private"/>
							<child value="static"/>
						<string-list/>
						<symbol for="type" value="Path"/>
					<definition/>
					<params/>
					<children>
						<any value="return Application.ROOT_DIRECTORY.resolve("src")
                .resolve("magma")
                .resolve("Main.java");"/>
					<children/>
				<method/>
			<children/>
		<class/>
	<children/>
<block/>
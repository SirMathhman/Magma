{
  "compilerOptions": {
    "target": "es5",
    "module": "commonjs",
    "rootDirs": [
      "./src/node"
    ],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": false
  },
  "exclude": [
    "**/*.js",
    "out",
    "node_modules"
  ]
}

{
  "compilerOptions": {
    "target": "es5",
    "module": "commonjs",
    "outDir": "./out/node",
    "rootDir": "./src/node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": false
  },
  "include": [
    "src/node/**/*"
  ],
  "exclude": [
    "**/*.js",
    "out",
    "node_modules"
  ]
}
